
# --- Aplicación ---
APP_ENV=development

# --- PostgreSQL ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=gestion_equipos

# --- MongoDB ---
MONGO_URI=mongodb://localhost:27017
MONGO_DB=gestion_equipos

# --- Seguridad---
JWT_SECRET=tfg-universidad-siglo-xxi
JWT_EXPIRE_MINUTES=60
MAX_INTENTOS_LOGIN=5
BLOQUEO_MINUTOS=15

# --- IA (Gemini) ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite
# Pool de modelos a rotar ante fallos/cuota (separados por coma, en orden de preferencia).
GEMINI_MODELOS=gemini-2.5-flash-lite,gemini-2.5-flash,gemini-3-flash-preview,gemini-3.1-flash-lite,gemini-3.5-flash
# Minutos que un modelo queda "tmp_out" tras fallar antes de reusarlo.
GEMINI_TMP_OUT_MINUTOS=10
LLM_TIMEOUT_SEGUNDOS=30
LLM_MAX_REINTENTOS=3

# --- Primer Líder Técnico ---
BOOTSTRAP_ADMIN_EMAIL=lider@demo.com
BOOTSTRAP_ADMIN_PASSWORD=Lider123!
BOOTSTRAP_ADMIN_NOMBRE=Líder Técnico
